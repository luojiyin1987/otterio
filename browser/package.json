{
  "name": "otterio-browser",
  "version": "0.0.1",
  "description": "OtterIO Browser",
  "scripts": {
    "test": "jest",
    "dev": "NODE_ENV=dev webpack serve --config webpack.dev.js",
    "build": "NODE_ENV=dev node build.js",
    "release": "NODE_ENV=production node build.js",
    "format": "prettier --write 'app/js/**/*.js' 'webpack.*.js' build.js",
    "format:check": "prettier --check 'app/js/**/*.js' 'webpack.*.js' build.js"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not IE 11"
  ],
  "jest": {
    "testEnvironment": "jsdom",
    "testEnvironmentOptions": {
      "url": "https://localhost:8080"
    },
    "setupFilesAfterEnv": [
      "./app/js/jest/setup.js"
    ],
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/app/js/jest/__mocks__/fileMock.js",
      "\\.(css|scss|less)$": "identity-obj-proxy"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/soulteary/otterio"
  },
  "author": "soulteary",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/soulteary/otterio/issues"
  },
  "homepage": "https://github.com/soulteary/otterio",
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "babel-jest": "^29.7.0",
    "babel-loader": "^9.2.1",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.11.0",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "glob-all": "^3.3.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "less": "^4.2.1",
    "less-loader": "^11.1.4",
    "mini-css-extract-plugin": "^2.10.2",
    "prettier": "^3.8.3",
    "purgecss-webpack-plugin": "^5.0.0",
    "redux-mock-store": "^1.5.5",
    "redux-thunk": "^2.4.2",
    "style-loader": "^3.3.4",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.0",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^5.15.4",
    "@reduxjs/toolkit": "^2.12.0",
    "bootstrap": "^5",
    "classnames": "^2.5.1",
    "core-js": "^3.39.0",
    "dayjs": "^1.11.21",
    "filesize": "^11.0.17",
    "history": "^5",
    "jwt-decode": "^4",
    "local-storage-fallback": "^4.1.2",
    "mime-db": "^1.53.0",
    "mime-types": "^2.1.35",
    "path-browserify": "^1.0.1",
    "query-string": "^8",
    "react": "^18",
    "react-bootstrap": "^2",
    "react-copy-to-clipboard": "^5.1.0",
    "react-dom": "^18",
    "react-dropzone": "^11.7.1",
    "react-infinite-scroller": "^1.2.6",
    "react-qr-code": "^1.1.1",
    "react-redux": "^9",
    "react-router-dom": "^6"
  }
}
